<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>LABIB STOP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
                    colors: { primary: '#059669', dark: '#064E3B' }
                }
            }
        }
    </script>

    <style>
        ::-webkit-scrollbar { display: none; }
        body { background: #F8FAFC; scrollbar-width: none; }
        .glass-nav { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border-top: 1px solid rgba(0,0,0,0.05); }
        .offer-card { background: linear-gradient(135deg, #059669 0%, #10b981 100%); position: relative; overflow: hidden; }
        .offer-card::after { content: ''; position: absolute; right: -20px; bottom: -20px; width: 120px; height: 120px; background: rgba(255,255,255,0.1); border-radius: 50%; }
        .product-card { background: white; border-radius: 2.5rem; padding: 12px; transition: transform 0.2s; box-shadow: 0 4px 15px rgba(0,0,0,0.02); }
        .product-card:active { transform: scale(0.96); }
        .category-btn { transition: all 0.3s; border-radius: 1.2rem; font-weight: 700; font-size: 14px; }
        .modal-sheet { animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1); border-radius: 3rem 3rem 0 0; }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
    </style>
</head>
<body class="text-slate-800">

    <div id="toast-container" class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] w-full max-w-xs px-4"></div>

    <header class="p-6 flex justify-between items-center sticky top-0 z-40 bg-[#F8FAFC]/80 backdrop-blur-md">
        <div>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Welcome to</p>
            <h1 class="text-2xl font-black text-emerald-600 flex items-center gap-2">LABIB STOP <i class="fa-solid fa-bag-shopping text-emerald-500"></i></h1>
        </div>
        <div class="relative" onclick="switchTab('cart')">
            <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                <i class="fa-solid fa-cart-shopping text-xl"></i>
            </div>
            <span id="cart-count" class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] rounded-full hidden border-2 border-white flex items-center justify-center font-bold">0</span>
        </div>
    </header>

    <main class="pb-32">
        <section id="sec-home" class="p-6 space-y-6">
            <div class="offer-card p-8 rounded-[2.5rem] text-white shadow-xl shadow-emerald-100">
                <span class="bg-emerald-400/30 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider">Special Offer</span>
                <h2 class="text-3xl font-black mt-2">Best Quality</h2>
                <p class="text-sm opacity-90 mt-1 font-medium italic">Contact: 01964905827</p>
            </div>

            <div class="flex gap-3 overflow-x-auto pb-2 no-scrollbar">
                <button onclick="filterCat('All')" class="category-btn px-6 py-3 bg-emerald-600 text-white shadow-lg shadow-emerald-100">All</button>
                <button onclick="filterCat('Electronics')" class="category-btn px-6 py-3 bg-white text-slate-400 border border-slate-100">Electronics</button>
                <button onclick="filterCat('Fashion')" class="category-btn px-6 py-3 bg-white text-slate-400 border border-slate-100">Fashion</button>
            </div>

            <h3 class="text-xl font-black text-dark">Available Products</h3>
            <div id="product-grid" class="grid grid-cols-2 gap-5">
                </div>
        </section>

        <section id="sec-cart" class="hidden p-6 space-y-4">
            <h2 class="text-xl font-black px-2">Your Basket</h2>
            <div id="cart-list" class="space-y-4"></div>
            <div id="cart-total-box" class="hidden bg-white p-8 rounded-[3rem] shadow-sm border border-slate-100 space-y-4">
                <button onclick="openCheckout('cart')" class="w-full py-5 bg-emerald-600 text-white rounded-[1.8rem] font-black uppercase text-xs tracking-widest shadow-lg shadow-emerald-100">Checkout Basket</button>
            </div>
        </section>

        <section id="sec-profile" class="hidden p-6 space-y-6">
            <div class="bg-white p-8 rounded-[3rem] shadow-sm border border-slate-50 text-center">
                <div class="w-20 h-20 bg-emerald-100 rounded-[2rem] flex items-center justify-center text-emerald-600 text-3xl mx-auto mb-4">
                    <i class="fa-solid fa-user-check"></i>
                </div>
                <h3 class="font-black text-lg">My Information</h3>
            </div>
            <div class="bg-white p-8 rounded-[3rem] shadow-sm border border-slate-100 space-y-4">
                <input type="text" id="prof-name" placeholder="Full Name" class="w-full px-6 py-4 bg-slate-50 rounded-2xl border-none text-sm">
                <input type="number" id="prof-phone" placeholder="Mobile Number" class="w-full px-6 py-4 bg-slate-50 rounded-2xl border-none text-sm">
                <textarea id="prof-address" placeholder="Address (Example: Dhaka)" class="w-full px-6 py-4 bg-slate-50 rounded-2xl border-none text-sm" rows="3"></textarea>
                <button onclick="saveProfile()" class="w-full py-5 bg-dark text-white rounded-[2rem] font-black uppercase text-[10px] tracking-widest">Save Profile</button>
            </div>
        </section>
    </main>

    <nav class="glass-nav fixed bottom-8 left-8 right-8 h-18 rounded-[2.2rem] flex items-center justify-around px-2 z-50 shadow-2xl border border-white/50">
        <button onclick="switchTab('home')" id="nav-home" class="flex flex-col items-center gap-1 text-emerald-600"><i class="fa-solid fa-house text-lg"></i><span class="text-[9px] font-bold">Home</span></button>
        <button onclick="switchTab('orders')" id="nav-orders" class="flex flex-col items-center gap-1 text-slate-400"><i class="fa-solid fa-receipt text-lg"></i><span class="text-[9px] font-bold">Orders</span></button>
        <button onclick="switchTab('cart')" id="nav-cart" class="flex flex-col items-center gap-1 text-slate-400"><i class="fa-solid fa-cart-shopping text-lg"></i><span class="text-[9px] font-bold">Cart</span></button>
        <button onclick="switchTab('profile')" id="nav-profile" class="flex flex-col items-center gap-1 text-slate-400"><i class="fa-solid fa-user text-lg"></i><span class="text-[9px] font-bold">Profile</span></button>
    </nav>

    <div id="product-modal" class="fixed inset-0 z-[60] hidden">
        <div class="absolute inset-0 bg-dark/40 backdrop-blur-sm" onclick="closeModal()"></div>
        <div class="absolute bottom-0 left-0 right-0 bg-white modal-sheet p-10 max-h-[90vh] overflow-y-auto">
            <div id="modal-content"></div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-app.js";
        import { getFirestore, collection, addDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-firestore.js";

        const firebaseConfig = {
          apiKey: "AIzaSyDmzMnz-vxXqCMBoIZfiRw5d1YaXibMW0E",
          authDomain: "labib-stor.firebaseapp.com",
          databaseURL: "https://labib-stor-default-rtdb.firebaseio.com",
          projectId: "labib-stor",
          storageBucket: "labib-stor.firebasestorage.app",
          messagingSenderId: "403219037342",
          appId: "1:403219037342:web:b21aa4cbc41bc9191acf8f"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        let products = [];
        let cart = [];
        let bQty = 1;

        onSnapshot(collection(db, "products"), (snap) => {
            products = snap.docs.map(d => ({id: d.id, ...d.data()}));
            renderProducts();
        });

        function renderProducts() {
            const grid = document.getElementById('product-grid');
            grid.innerHTML = products.map(p => `
                <div class="product-card" onclick="showDetails('${p.id}')">
                    <img src="${p.imageUrl}" class="w-full aspect-square object-cover rounded-[1.8rem] mb-3">
                    <h4 class="text-[11px] font-black text-slate-500 uppercase px-1 truncate">${p.title}</h4>
                    <p class="text-emerald-600 font-black text-lg px-1">৳${p.price}</p>
                </div>
            `).join('');
        }

        window.showDetails = (id) => {
            const p = products.find(x => x.id === id);
            bQty = 1;
            document.getElementById('modal-content').innerHTML = `
                <div class="flex justify-center mb-8"><img src="${p.imageUrl}" class="w-56 h-56 object-cover rounded-[2.5rem] shadow-2xl"></div>
                <h3 class="text-2xl font-black text-dark text-center leading-tight">${p.title}</h3>
                <p class="text-emerald-500 font-black text-3xl mt-2 text-center">৳${p.price}</p>
                
                <div class="flex items-center justify-between mt-8 bg-slate-50 p-5 rounded-[1.8rem]">
                    <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Quantity</span>
                    <div class="flex items-center gap-6">
                        <button onclick="updateBQty(-1)" class="w-10 h-10 rounded-full bg-white shadow-sm flex items-center justify-center font-bold text-emerald-600 border border-slate-100">-</button>
                        <span id="b-qty" class="font-black text-xl">1</span>
                        <button onclick="updateBQty(1)" class="w-10 h-10 rounded-full bg-emerald-600 text-white shadow-lg flex items-center justify-center font-bold">+</button>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mt-8">
                    <button onclick="addToCart('${p.id}')" class="py-5 bg-emerald-50 text-emerald-600 rounded-[1.5rem] font-black uppercase text-[10px] tracking-widest">Add To Cart</button>
                    <button onclick="openCheckout('${p.id}')" class="py-5 bg-emerald-600 text-white rounded-[1.5rem] font-black uppercase text-[10px] tracking-widest shadow-xl shadow-emerald-100">Buy It Now</button>
                </div>
            `;
            document.getElementById('product-modal').classList.remove('hidden');
        };

        window.updateBQty = (v) => { bQty = Math.max(1, bQty + v); document.getElementById('b-qty').innerText = bQty; };

        window.openCheckout = (target) => {
            const profile = JSON.parse(localStorage.getItem('labib_profile')) || {};
            let items = target === 'cart' ? cart : [{...products.find(x => x.id === target), qty: bQty}];
            const sub = items.reduce((a, c) => a + (c.price * c.qty), 0);
            const initialCharge = (profile.address && /dhaka|ঢাকা/i.test(profile.address)) ? 60 : 120;

            document.getElementById('modal-content').innerHTML = `
                <h3 class="text-xl font-black text-dark mb-6 text-center">Checkout Order</h3>
                <div class="space-y-4">
                    <input type="text" id="o-name" value="${profile.name || ''}" placeholder="Full Name" class="w-full px-6 py-4 bg-slate-50 rounded-2xl border-none text-sm">
                    <input type="number" id="o-phone" value="${profile.phone || ''}" placeholder="Mobile Number" class="w-full px-6 py-4 bg-slate-50 rounded-2xl border-none text-sm">
                    <textarea id="o-addr" oninput="reCalc(${sub}, this.value)" placeholder="Address (Dhaka/Outside)" class="w-full px-6 py-4 bg-slate-50 rounded-2xl border-none text-sm" rows="2">${profile.address || ''}</textarea>
                    
                    <div class="bg-emerald-600 p-8 rounded-[2.5rem] text-white space-y-2 mt-6">
                        <div class="flex justify-between text-xs font-bold opacity-75 uppercase"><span>Products:</span><span>৳${sub}</span></div>
                        <div class="flex justify-between text-xs font-bold opacity-75 uppercase"><span>Delivery:</span><span id="c-charge">৳${initialCharge}</span></div>
                        <hr class="border-white/10 my-2">
                        <div class="flex justify-between font-black text-2xl uppercase italic"><span>Total:</span><span id="c-total">৳${sub + initialCharge}</span></div>
                    </div>

                    <button id="conf-btn" onclick="confirmOrder('${target}')" class="w-full py-5 bg-dark text-white rounded-[1.8rem] font-black uppercase text-[10px] tracking-widest shadow-2xl mt-4">Confirm Order</button>
                </div>
            `;
        };

        window.reCalc = (sub, addr) => {
            const charge = /dhaka|ঢাকা/i.test(addr) ? 60 : 120;
            document.getElementById('c-charge').innerText = `৳${charge}`;
            document.getElementById('c-total').innerText = `৳${sub + charge}`;
        };

        window.confirmOrder = async (target) => {
            const name = document.getElementById('o-name').value;
            const phone = document.getElementById('o-phone').value;
            const address = document.getElementById('o-addr').value;
            const charge = /dhaka|ঢাকা/i.test(address) ? 60 : 120;

            if(!name || !phone || !address) return showToast("Information required!", "error");

            const btn = document.getElementById('conf-btn');
            btn.disabled = true; btn.innerText = "Processing...";

            try {
                let items = target === 'cart' ? cart : [{...products.find(x => x.id === target), qty: bQty}];
                await addDoc(collection(db, "orders"), {
                    userName: name, userPhone: phone, userAddress: address,
                    items: items, deliveryCharge: charge, status: 'Pending',
                    createdAt: new Date().toISOString()
                });
                if(target === 'cart') cart = [];
                updateCartUI(); closeModal();
                showToast("Order Successful! 🚀");
                switchTab('home');
            } catch (e) { showToast("Failed to place order", "error"); }
            finally { btn.disabled = false; }
        };

        window.addToCart = (id) => {
            const p = products.find(x => x.id === id);
            const exists = cart.find(x => x.id === id);
            if(exists) exists.qty += bQty;
            else cart.push({...p, qty: bQty});
            updateCartUI();
            showToast("Added to Bag!");
            closeModal();
        };

        function updateCartUI() {
            const count = document.getElementById('cart-count');
            count.innerText = cart.length; count.classList.toggle('hidden', cart.length === 0);
            
            const list = document.getElementById('cart-list');
            if(cart.length === 0) {
                list.innerHTML = `<div class="py-20 text-center opacity-20"><i class="fa-solid fa-cart-arrow-down text-6xl"></i><p class="font-black mt-4 uppercase">Cart Empty</p></div>`;
                document.getElementById('cart-total-box').classList.add('hidden');
                return;
            }
            list.innerHTML = cart.map((i, idx) => `
                <div class="bg-white p-5 rounded-[2rem] flex gap-4 items-center shadow-sm">
                    <img src="${i.imageUrl}" class="w-16 h-16 object-cover rounded-2xl">
                    <div class="flex-1"><h5 class="text-xs font-black text-slate-500 uppercase">${i.title}</h5><p class="text-emerald-600 font-black">৳${i.price}</p></div>
                    <div class="flex items-center gap-3 bg-slate-50 p-2 rounded-xl">
                        <button onclick="changeQty(${idx}, -1)" class="w-6 h-6 flex items-center justify-center font-bold text-slate-300">-</button>
                        <span class="text-xs font-black">${i.qty}</span>
                        <button onclick="changeQty(${idx}, 1)" class="w-6 h-6 flex items-center justify-center font-bold text-emerald-600">+</button>
                    </div>
                </div>
            `).join('');
            document.getElementById('cart-total-box').classList.remove('hidden');
        }

        window.changeQty = (idx, v) => {
            cart[idx].qty += v;
            if(cart[idx].qty <= 0) cart.splice(idx, 1);
            updateCartUI();
        };

        window.saveProfile = () => {
            const p = { name: document.getElementById('prof-name').value, phone: document.getElementById('prof-phone').value, address: document.getElementById('prof-address').value };
            localStorage.setItem('labib_profile', JSON.stringify(p));
            showToast("Profile Updated!");
        };

        window.switchTab = (tab) => {
            ['home', 'cart', 'profile'].forEach(t => {
                document.getElementById(`sec-${t}`).classList.add('hidden');
                document.getElementById(`nav-${t}`).className = "flex flex-col items-center gap-1 text-slate-400";
            });
            document.getElementById(`sec-${tab}`).classList.remove('hidden');
            document.getElementById(`nav-${tab}`).className = "flex flex-col items-center gap-1 text-emerald-600";
            if(tab === 'profile') {
                const p = JSON.parse(localStorage.getItem('labib_profile')) || {};
                document.getElementById('prof-name').value = p.name || '';
                document.getElementById('prof-phone').value = p.phone || '';
                document.getElementById('prof-address').value = p.address || '';
            }
        };

        window.closeModal = () => document.getElementById('product-modal').classList.add('hidden');

        window.showToast = (m, t='success') => {
            const toast = document.createElement('div');
            toast.className = `p-5 rounded-[2rem] shadow-2xl flex items-center gap-3 animate-pop mb-3 ${t === 'success' ? 'bg-emerald-600 text-white' : 'bg-red-600 text-white'}`;
            toast.innerHTML = `<i class="fa-solid ${t === 'success' ? 'fa-circle-check' : 'fa-triangle-exclamation'}"></i><p class="text-[10px] font-black uppercase tracking-widest">${m}</p>`;
            document.getElementById('toast-container').appendChild(toast);
            setTimeout(() => toast.remove(), 2500);
        };
    </script>
</body>
</html>